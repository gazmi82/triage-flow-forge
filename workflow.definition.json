{
  "schemaVersion": "1.4.0",
  "definition": {
    "id": "def.emergency_triage.v6",
    "key": "emergency_triage",
    "name": "Emergency Triage",
    "version": 6,
    "status": "draft",
    "description": "Task Console is the entry point. Process Designer is a read-only projection of task-created nodes. Admin includes user provisioning with role assignment.",
    "lanes": [
      "reception",
      "triage_nurse",
      "physician",
      "lab",
      "radiology"
    ],
    "accessControl": {
      "roles": [
        "admin",
        "reception",
        "triage_nurse",
        "physician",
        "lab",
        "radiology"
      ],
      "routePermissions": [
        {
          "role": "admin",
          "allow": [
            "dashboard",
            "process_designer",
            "task_console",
            "draft",
            "saved_tasks",
            "instance_monitor",
            "admin",
            "docs"
          ]
        },
        {
          "role": "non_admin",
          "allow": [
            "process_designer",
            "task_console",
            "draft",
            "saved_tasks",
            "docs"
          ]
        }
      ]
    }
  },
  "uxContract": {
    "taskConsole": {
      "isProcessEntryPoint": true,
      "createTaskButton": {
        "enabled": true,
        "createsNodeInGraph": true,
        "linkFromSelectedTaskNode": true,
        "ifGraphEmpty": "auto_create_start_event_then_link"
      },
      "propertiesPanel": {
        "location": "task_console_only",
        "fields": [
          "shapeType",
          "label",
          "assignedRole"
        ]
      },
      "assignedRoleSelection": {
        "enabled": true,
        "scope": "all_supported_roles_except_admin"
      },
      "urgencyStatusSelection": {
        "enabled": true,
        "type": "single_select",
        "options": [
          { "label": "Immediate", "triageColor": "red" },
          { "label": "Very urgent", "triageColor": "orange" },
          { "label": "Urgent", "triageColor": "yellow" },
          { "label": "Standard", "triageColor": "green" },
          { "label": "Non-urgent", "triageColor": "blue" }
        ]
      },
      "slaPolicy": {
        "source": "urgency_status",
        "targetsMinutes": {
          "red": 0,
          "orange": 10,
          "yellow": 60,
          "green": 120,
          "blue": 240
        },
        "resetTimerOnUrgencyChange": true
      },
      "roleRules": {
        "reception": {
          "defaultShapeType": "userTask",
          "defaultFields": [
            "patient_name",
            "patient_id",
            "registration_note"
          ],
          "mustChooseRedirectRole": true
        }
      }
    },
    "processDesigner": {
      "mode": "read_only_projection",
      "showBpmnElementsPalette": false,
      "showPropertiesPanel": false,
      "editableFromDesigner": false,
      "taskScopedProjection": {
        "enabled": true,
        "scopeKey": "instanceId",
        "includesAllTasksInInstance": true
      }
    },
    "adminConsole": {
      "usersAndRoles": {
        "createUser": {
          "enabled": true,
          "fields": [
            "name",
            "email",
            "password",
            "role",
            "department"
          ],
          "validations": {
            "nameMinLength": 2,
            "emailFormat": "required",
            "emailUnique": true,
            "passwordMinLength": 6,
            "departmentMinLength": 2
          },
          "defaultActiveStatus": true
        }
      }
    }
  },
  "stateManagement": {
    "driver": "redux_toolkit",
    "sourceOfTruth": "mockData_api",
    "syncRules": {
      "task_console_create_to_designer": "creating node/task in task console updates designer graph immediately",
      "task_console_claim_complete_to_designer": "task status changes mirror node taskStatus",
      "designer_publish_to_task_console": "publish rebuilds task list from userTask nodes",
      "draft_save_load": "save stores graph snapshots; load injects snapshot into designer state",
      "task_redirect_to_designer": "opening process design from a task loads the graph for that task instanceId",
      "saved_tasks_registry": "saved tasks keeps all task records with process status and supports process redirection",
      "admin_user_create": "admin create-user writes user + credential records and updates workflow users state",
      "active_instance_projection": "active/open instance summaries are derived from non-completed tasks, not only persisted instance status"
    }
  },
  "bpmnSubsetProfile": {
    "name": "triage-bpmn-subset-v1",
    "baseSpec": "OMG BPMN 2.0.2",
    "conformance": "descriptive_subset",
    "supportedElements": {
      "events": [
        "startEvent",
        "endEvent",
        "timerEvent",
        "messageEvent",
        "signalEvent"
      ],
      "activities": [
        "userTask"
      ],
      "gateways": [
        "xorGateway",
        "andGateway"
      ],
      "flowConnectors": [
        "sequenceFlow"
      ],
      "lanes": [
        "reception",
        "triage_nurse",
        "physician",
        "lab",
        "radiology"
      ]
    },
    "executionSemantics": {
      "sourceOfTruth": "task_console",
      "designerProjection": "read_only",
      "startRule": "first_non_start_node_autocreates_startEvent",
      "endRule": "endEvent_closes_instance_when_no_open_tasks",
      "gatewayRules": {
        "xorGateway": "single_outgoing_sequence_chosen_by_condition_or_operator",
        "andGateway": "all_outgoing_sequences_open_parallel_work"
      },
      "eventRules": {
        "timerEvent": "creates_or_updates_sla_wait_state",
        "messageEvent": "waits_for_external_payload_with_optional_correlation_key",
        "signalEvent": "broadcast_style_transition_across_matching_instances_optional"
      }
    },
    "validationRules": {
      "requiredPerProcess": [
        "at_least_one_startEvent",
        "at_least_one_endEvent"
      ],
      "nodeConstraints": {
        "startEvent": {
          "incomingSequenceMax": 0
        },
        "endEvent": {
          "outgoingSequenceMax": 0
        },
        "userTask": {
          "requiresAssignedRole": true,
          "requiresLabel": true
        }
      },
      "edgeConstraints": {
        "allowedEdgeTypes": [
          "sequenceFlow"
        ],
        "disallowSelfLoop": true
      }
    },
    "serialization": {
      "primary": "workflow.definition.json",
      "runtimeGraph": "redux_workflow_state",
      "bpmnXmlImportExport": "planned_not_implemented"
    }
  },
  "graph": {
    "initialState": {
      "nodes": [],
      "edges": []
    },
    "supportedNodeTypes": [
      "startEvent",
      "endEvent",
      "userTask",
      "xorGateway",
      "andGateway",
      "timerEvent",
      "messageEvent",
      "signalEvent"
    ],
    "supportedEdgeTypes": [
      "sequenceFlow"
    ]
  }
}
